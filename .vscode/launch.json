{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug webserv",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/webserv",
			"args": ["conf/example_1.conf"],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"preLaunchTask": "build",
			"MIMode": "gdb",
			"setupCommands": [
				{
					"description": "Pretty printing",
					"text": "-enable-pretty-printing",
					"ignoreFailures": true
				}
			]
		}
	]
}
